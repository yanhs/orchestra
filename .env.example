# ============================================================
# .env.example — шаблон переменных окружения для Orchestra
# Скопируй в .env и заполни своими значениями:
#   cp .env.example .env
# ============================================================

# ──────────────────────────────────────────────
# ОБЯЗАТЕЛЬНЫЕ переменные
# ──────────────────────────────────────────────

# Ключ Anthropic API (получить на https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ──────────────────────────────────────────────
# Настройки веб-сервера
# ──────────────────────────────────────────────

# Порт на хосте (контейнер всегда слушает 3015)
ORCHESTRA_PORT=3015

# Хост для привязки внутри контейнера
ORCHESTRA_HOST=0.0.0.0

# ──────────────────────────────────────────────
# Настройки Claude / агентов
# ──────────────────────────────────────────────

# Модель по умолчанию (если не задана в конфигурации агентов)
# Варианты: claude-opus-4-5, claude-sonnet-4-5, claude-haiku-4-5
CLAUDE_DEFAULT_MODEL=claude-sonnet-4-5

# Максимальный токенов на ответ (0 = без ограничения)
CLAUDE_MAX_TOKENS=8192

# Таймаут запроса к API в секундах
CLAUDE_TIMEOUT=120

# ──────────────────────────────────────────────
# Пути к файлам данных
# ──────────────────────────────────────────────

# Директория для хранения jobs, runs, sessions
# В Docker монтируется как volume orchestra_data → /app/_orchestra
ORCHESTRA_DATA_DIR=./_orchestra

# Путь к файлу конфигурации агентов
ORCHESTRA_CONFIG=./config/agents.yaml

# ──────────────────────────────────────────────
# Логирование
# ──────────────────────────────────────────────

# Уровень логов: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Формат логов: text, json
LOG_FORMAT=json

# ──────────────────────────────────────────────
# Опциональные инструменты агентов
# ──────────────────────────────────────────────

# Разрешить агентам использовать веб-поиск
ALLOW_WEB_SEARCH=true

# Разрешить агентам использовать Bash-команды (осторожно в prod!)
ALLOW_BASH=false

# ──────────────────────────────────────────────
# CORS (если используется фронтенд на другом домене)
# ──────────────────────────────────────────────

# Разрешённые Origins через запятую (* = все)
CORS_ORIGINS=*
